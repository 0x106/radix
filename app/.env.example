# Radix environment — copy to `.env` and fill in real values. `.env` is gitignored.
#
# Public Instant app id. Safe to expose to the browser (hence NEXT_PUBLIC_).
NEXT_PUBLIC_INSTANT_APP_ID=your-instant-app-id

# Instant admin token. SECRET — full database access, bypasses permission rules.
# Used only by local dev tooling (src/publish/). Never expose to the browser or
# commit a real value.
INSTANT_APP_ADMIN_TOKEN=your-instant-admin-token

# OpenAI credentials for the agent. SECRET.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.5

# --- Stripe billing ---------------------------------------------------------
# Stripe secret key. SECRET.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret. From the Stripe dashboard, or printed by
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` for local dev.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Stripe Price IDs for the token packs and the monthly subscription. Create the
# products/prices in the Stripe dashboard; token amounts live in src/lib/products.ts.
STRIPE_PRICE_PACK_SMALL=price_xxx_500_tokens
STRIPE_PRICE_PACK_MEDIUM=price_xxx_2000_tokens
STRIPE_PRICE_PACK_LARGE=price_xxx_6000_tokens
STRIPE_PRICE_SUBSCRIPTION=price_xxx_monthly
# Public base URL, used for Stripe success/cancel + portal return URLs.
# Optional locally (falls back to the request origin); set in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
